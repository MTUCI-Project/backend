datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== USERS ====================

model User {
  id       String @id @default(uuid())
  username String @unique
  password String @map("password_hash")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  isBanned Boolean @default(false)

  assignments        RoleAssignment[]    @relation("RoleAssignments_User")
  assignmentsCreated RoleAssignment[]    @relation("RoleAssignments_Creator")
  coupleLinksCreated CoupleLink[]        @relation("CoupleLinks_Creator")
  coupleLinksAsUserA CoupleLink[]        @relation("CoupleLinks_UserA")
  coupleLinksAsUserB CoupleLink[]        @relation("CoupleLinks_UserB")
  onboardingAnswers  OnboardingAnswer[]
  events             UserEvent[]
  todos              Todo[]
  reminders          Reminder[]
  sponsorOffers      SponsorOffer[]
  sponsorSuggestions SponsorSuggestion[]

  @@index([createdAt])
  @@index([deletedAt])
  @@index([isBanned])
}

// ==================== COMPANION DOMAIN ====================

enum CoupleLinkStatus {
  pending
  active
  declined
  revoked
}

enum DomainSource {
  user
  ai
  system
}

enum TodoStatus {
  open
  done
  dismissed
  cancelled
}

enum ReminderStatus {
  scheduled
  sent
  dismissed
  done
  cancelled
}

enum ReminderChannel {
  push
  in_app
  email
}

enum SponsorOfferStatus {
  proposed
  accepted
  dismissed
  expired
}

enum SponsorSuggestionStatus {
  pending
  sent
  dismissed
  clicked
  converted
  expired
}

model SponsorProduct {
  id          String  @id @default(uuid())
  title       String
  description String
  referralUrl String
  sponsorName String
  imageUrl    String?
  priceLabel  String?
  category    String?
  tags        Json    @default("[]")
  metadata    Json    @default("{}")
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  offers      SponsorOffer[]
  suggestions SponsorSuggestion[]

  @@index([isActive, deletedAt])
  @@index([sponsorName])
  @@index([category])
}

model CoupleLink {
  id          String           @id @default(uuid())
  userAId     String
  userBId     String?
  status      CoupleLinkStatus @default(pending)
  inviteCode  String           @unique
  createdById String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  acceptedAt DateTime?
  revokedAt  DateTime?

  userA     User  @relation("CoupleLinks_UserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User? @relation("CoupleLinks_UserB", fields: [userBId], references: [id], onDelete: SetNull)
  createdBy User  @relation("CoupleLinks_Creator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userAId, status])
  @@index([userBId, status])
  @@index([createdById])
}

model OnboardingAnswer {
  id          String       @id @default(uuid())
  userId      String
  questionKey String
  answer      Json
  source      DomainSource @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionKey])
  @@index([userId, updatedAt])
}

model UserEvent {
  id          String       @id @default(uuid())
  userId      String
  title       String
  description String?
  eventAt     DateTime?
  timezone    String?
  source      DomainSource @default(user)
  metadata    Json         @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos              Todo[]
  reminders          Reminder[]
  sponsorOffers      SponsorOffer[]
  sponsorSuggestions SponsorSuggestion[]

  @@index([userId, eventAt])
  @@index([userId, deletedAt])
}

model Todo {
  id       String       @id @default(uuid())
  userId   String
  eventId  String?
  title    String
  status   TodoStatus   @default(open)
  dueAt    DateTime?
  source   DomainSource @default(user)
  metadata Json         @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  event              UserEvent?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reminders          Reminder[]
  sponsorOffers      SponsorOffer[]
  sponsorSuggestions SponsorSuggestion[]

  @@index([userId, status])
  @@index([userId, dueAt])
  @@index([eventId])
  @@index([userId, deletedAt])
}

model SponsorOffer {
  id          String             @id @default(uuid())
  userId      String
  productId   String?
  eventId     String?
  todoId      String?
  title       String
  description String?
  url         String?
  sponsorName String
  placement   String
  status      SponsorOfferStatus @default(proposed)
  metadata    Json               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product SponsorProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  event   UserEvent?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  todo    Todo?           @relation(fields: [todoId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([productId])
  @@index([eventId])
  @@index([todoId])
}

model SponsorSuggestion {
  id         String                  @id @default(uuid())
  userId     String
  productId  String
  eventId    String?
  todoId     String?
  reminderId String?
  title      String?
  message    String?
  placement  String
  reason     String?
  status     SponsorSuggestionStatus @default(pending)
  metadata   Json                    @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deliveredAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  SponsorProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  event    UserEvent?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  todo     Todo?          @relation(fields: [todoId], references: [id], onDelete: SetNull)
  reminder Reminder?      @relation(fields: [reminderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([productId])
  @@index([eventId])
  @@index([todoId])
  @@index([reminderId])
}

model Reminder {
  id        String          @id @default(uuid())
  userId    String
  eventId   String?
  todoId    String?
  triggerAt DateTime
  status    ReminderStatus  @default(scheduled)
  channel   ReminderChannel @default(push)
  payload   Json            @default("{}")
  source    DomainSource    @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  event              UserEvent?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  todo               Todo?               @relation(fields: [todoId], references: [id], onDelete: SetNull)
  sponsorSuggestions SponsorSuggestion[]

  @@index([userId, triggerAt])
  @@index([userId, status])
  @@index([eventId])
  @@index([todoId])
}

// ==================== RBAC ====================

model Role {
  id          String  @id @default(uuid())
  key         String  @unique
  name        String
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  assignments RoleAssignment[]

  @@index([key])
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@index([key])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model RoleAssignment {
  id     String @id @default(uuid())
  userId String
  roleId String

  createdAt   DateTime @default(now())
  createdById String?

  user User @relation("RoleAssignments_User", fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdBy User? @relation("RoleAssignments_Creator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId])
}
