# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Logging
LOG_DIR=./logs
LOG_TO_FILE=true
LOG_APP_FILE_BASENAME=app.log
LOG_ACCESS_FILE_BASENAME=access.log
LOG_ERROR_FILE_BASENAME=error.log
LOG_ROTATE_INTERVAL=1d
LOG_ROTATE_SIZE=50M
LOG_MAX_FILES=14

# Jobs
JOBS_ENABLED=true
JOBS_TICK_MS=10000
JOBS_RUN_ON_START=true

# PostgreSQL
DATABASE_URL=postgresql://admin:admin123@localhost:5432/db?schema=public

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=media
MINIO_PRESIGN_EXPIRES=3600

# Authentication
JWT_SECRET=change-me-access-secret-at-least-32-characters
JWT_EXPIRES_IN=900
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=2592000

# Uploads
MAX_UPLOAD_BYTES=104857600

# Prisma seed
SEED_ADMIN_EMAIL=admin@local.dev
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345
